# name: test/sql/duckdb_api.test
# description: static public SQL and secret contract for 0.9.0
# group: [duckdb_api]

statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

require duckdb_api

query T
SELECT extension_version
FROM duckdb_extensions()
WHERE extension_name = 'duckdb_api';
----
0.9.0

# Accepted RFC 0012 removed the generic dispatcher before the 0.9.0 API
# candidate froze. It must remain absent from the installed product; every
# queryable relation is now a package-generated function (see
# test/python/artifact_contract.py and
# test/cpp/query/integration/package_product_contract_tests.cpp for their
# DESCRIBE/EXPLAIN/PREPARE and bind-diagnostic coverage).
statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

query TT
SELECT type, default_provider
FROM duckdb_secret_types()
WHERE type = 'duckdb_api';
----
duckdb_api	config

statement ok
CREATE TEMPORARY SECRET sql_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'sql-contract-sentinel'
);

query TTTTT
SELECT type, provider, storage, persistent, secret_string
FROM duckdb_secrets()
WHERE name = 'sql_contract';
----
duckdb_api	config	memory	false	name=sql_contract;type=duckdb_api;provider=config;serializable=true;scope;token=redacted

statement ok
DROP SECRET sql_contract;

statement error
CREATE SECRET persistent_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'rejected'
);
----
Invalid Input Error: [duckdb_api][authentication] duckdb_api secrets require explicit CREATE TEMPORARY SECRET
