# name: test/sql/duckdb_api.test
# description: static public SQL and secret contract for 0.10.0
# group: [duckdb_api]

statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

require duckdb_api

statement ok
SET secret_directory = '__TEST_DIR__/duckdb_api_credentials';

query T
SELECT extension_version
FROM duckdb_extensions()
WHERE extension_name = 'duckdb_api';
----
0.10.0

# Accepted RFC 0012 removed the generic dispatcher before the 0.9.0 API
# candidate froze. It must remain absent from the installed product; every
# queryable relation is now a package-generated function (see
# test/python/artifact_contract.py and
# test/cpp/query/integration/package_product_contract_tests.cpp for their
# DESCRIBE/EXPLAIN/PREPARE and bind-diagnostic coverage).
statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

query TT
SELECT type, default_provider
FROM duckdb_secret_types()
WHERE type = 'duckdb_api';
----
duckdb_api	config

statement ok
CREATE TEMPORARY SECRET sql_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'sql-contract-sentinel'
);

query TTTTT
SELECT type, provider, storage, persistent,
       secret_string LIKE '%token=redacted%'
       AND secret_string NOT LIKE '%sql-contract-sentinel%'
FROM duckdb_secrets()
WHERE name = 'sql_contract';
----
duckdb_api	config	memory	false	true

statement ok
DROP SECRET sql_contract;

statement ok
CREATE TEMPORARY SECRET environment_contract (
    TYPE duckdb_api,
    PROVIDER environment,
    VARIABLE 'DUCKDB_API_RFC_TRIAL'
);

query TTTTT
SELECT type, provider, storage, persistent,
       secret_string LIKE '%variable=redacted%'
       AND secret_string NOT LIKE '%DUCKDB_API_RFC_TRIAL%'
FROM duckdb_secrets()
WHERE name = 'environment_contract';
----
duckdb_api	environment	memory	false	true

statement ok
DROP TEMPORARY SECRET environment_contract;

statement ok
CREATE PERSISTENT SECRET persistent_contract IN duckdb_api (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'persistent-contract-sentinel'
);

query TTTTT
SELECT type, provider, storage, persistent,
       secret_string LIKE '%token=redacted%'
       AND secret_string NOT LIKE '%persistent-contract-sentinel%'
FROM duckdb_secrets()
WHERE name = 'persistent_contract';
----
duckdb_api	config	duckdb_api	true	true

statement ok
DROP PERSISTENT SECRET persistent_contract;

statement error
CREATE SECRET implicit_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'rejected'
);
----
Invalid Input Error: [duckdb_api][authentication] use explicit TEMPORARY memory storage or PERSISTENT IN duckdb_api storage
