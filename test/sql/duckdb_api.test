# name: test/sql/duckdb_api.test
# description: static duckdb_api SQL contract preserved by 0.3.0
# group: [duckdb_api]

statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

require duckdb_api

query T
SELECT extension_version
FROM duckdb_extensions()
WHERE extension_name = 'duckdb_api';
----
0.3.0

# DESCRIBE binds and plans the sole live relation without executing its source.
query TTTTTT
DESCRIBE SELECT *
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'duckdb_login_search_page'
);
----
id	BIGINT	YES	NULL	NULL	NULL
login	VARCHAR	YES	NULL	NULL	NULL
site_admin	BOOLEAN	YES	NULL	NULL	NULL

# PREPARE copies immutable bind data but does not acquire network authority.
statement ok
PREPARE live_scan AS
SELECT id, login, site_admin
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'duckdb_login_search_page'
)
ORDER BY id;

statement ok
DEALLOCATE live_scan;

