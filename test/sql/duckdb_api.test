# name: test/sql/duckdb_api.test
# description: accepted duckdb_api SQL contract preserved by 0.2.0
# group: [duckdb_api]

statement error
SELECT * FROM duckdb_api_scan(connector := 'example', relation := 'items');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

require duckdb_api

query T
SELECT extension_version
FROM duckdb_extensions()
WHERE extension_name = 'duckdb_api';
----
0.2.0

query ITI
SELECT id, name, active
FROM duckdb_api_scan(
    connector := 'example',
    relation := 'items'
)
ORDER BY id;
----
1	alpha	true
2	beta	false
3	gamma	true

# Each query discriminates one part of DuckDB's retained relational ownership.
query I
SELECT id
FROM duckdb_api_scan(connector := 'example', relation := 'items')
WHERE NOT active;
----
2

query I
SELECT id
FROM duckdb_api_scan(connector := 'example', relation := 'items')
ORDER BY id DESC;
----
3
2
1

query I
SELECT id
FROM duckdb_api_scan(connector := 'example', relation := 'items')
ORDER BY id
LIMIT 1 OFFSET 1;
----
2

query I
SELECT id
FROM duckdb_api_scan(connector := 'example', relation := 'items')
WHERE active
ORDER BY id
LIMIT 1 OFFSET 1;
----
3

statement error
SELECT * FROM duckdb_api_scan(connector := 'other', relation := 'items');
----
Binder Error: [duckdb_api][bind] unknown connector identifier

statement error
SELECT * FROM duckdb_api_scan(connector := 'example', relation := 'other');
----
Binder Error: [duckdb_api][bind] connector=example: unknown relation identifier

statement error
SELECT * FROM duckdb_api_scan(connector := 'example');
----
Binder Error: [duckdb_api][bind] required named argument relation is missing
