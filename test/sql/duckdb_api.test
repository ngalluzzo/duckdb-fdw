# name: test/sql/duckdb_api.test
# description: static public SQL and secret contract for 0.5.0
# group: [duckdb_api]

statement error
SELECT * FROM duckdb_api_scan(connector := 'github', relation := 'duckdb_login_search_page');
----
Catalog Error: Table Function with name duckdb_api_scan does not exist!

require duckdb_api

query T
SELECT extension_version
FROM duckdb_extensions()
WHERE extension_name = 'duckdb_api';
----
0.5.0

query TT
SELECT type, default_provider
FROM duckdb_secret_types()
WHERE type = 'duckdb_api';
----
duckdb_api	config

# DESCRIBE binds and plans the anonymous relation without executing its source.
query TTTTTT
DESCRIBE SELECT *
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'duckdb_login_search_page'
);
----
id	BIGINT	YES	NULL	NULL	NULL
login	VARCHAR	YES	NULL	NULL	NULL
site_admin	BOOLEAN	YES	NULL	NULL	NULL

# PREPARE copies immutable bind data but does not acquire network authority.
statement ok
PREPARE live_scan AS
SELECT id, login, site_admin
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'duckdb_login_search_page'
)
ORDER BY id;

statement ok
DEALLOCATE live_scan;

# Authenticated bind, describe, explain, and prepare retain only this logical
# name. They do not resolve the missing secret or acquire network authority.
query TTTTTT
DESCRIBE SELECT *
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_user',
    secret := 'offline_secret'
);
----
id	BIGINT	YES	NULL	NULL	NULL
login	VARCHAR	YES	NULL	NULL	NULL
site_admin	BOOLEAN	YES	NULL	NULL	NULL

statement ok
EXPLAIN SELECT *
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_user',
    secret := 'offline_secret'
);

statement ok
PREPARE authenticated_scan AS
SELECT id, login, site_admin
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_user',
    secret := 'offline_secret'
);

statement ok
DEALLOCATE authenticated_scan;

# The bounded repository relation is selected exactly and remains offline for
# describe, explain, and prepare. DuckDB owns presentation order.
query TTTTTT
DESCRIBE SELECT *
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_repositories',
    secret := 'offline_secret'
);
----
id	BIGINT	YES	NULL	NULL	NULL
full_name	VARCHAR	YES	NULL	NULL	NULL
private	BOOLEAN	YES	NULL	NULL	NULL
fork	BOOLEAN	YES	NULL	NULL	NULL
archived	BOOLEAN	YES	NULL	NULL	NULL

statement ok
EXPLAIN SELECT id, full_name, private, fork, archived
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_repositories',
    secret := 'offline_secret'
)
ORDER BY id;

statement ok
PREPARE authenticated_repositories_scan AS
SELECT id, full_name, private, fork, archived
FROM duckdb_api_scan(
    connector := 'github',
    relation := 'authenticated_repositories',
    secret := 'offline_secret'
)
ORDER BY id;

statement ok
DEALLOCATE authenticated_repositories_scan;

statement ok
CREATE TEMPORARY SECRET sql_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'sql-contract-sentinel'
);

query TTTTT
SELECT type, provider, storage, persistent, secret_string
FROM duckdb_secrets()
WHERE name = 'sql_contract';
----
duckdb_api	config	memory	false	name=sql_contract;type=duckdb_api;provider=config;serializable=true;scope;token=redacted

statement ok
DROP SECRET sql_contract;

statement error
CREATE SECRET persistent_contract (
    TYPE duckdb_api,
    PROVIDER config,
    TOKEN 'rejected'
);
----
Invalid Input Error: [duckdb_api][authentication] duckdb_api secrets require explicit CREATE TEMPORARY SECRET

