{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ngalluzzo/duckdb-fdw/release/public-surface/inventory.schema.json",
  "title": "duckdb-fdw canonical public SQL inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_release",
    "candidate_release",
    "planned_through",
    "shapes",
    "entries",
    "release_views"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "baseline_release": {
      "$ref": "#/$defs/semver"
    },
    "candidate_release": {
      "$ref": "#/$defs/semver"
    },
    "planned_through": {
      "$ref": "#/$defs/semver"
    },
    "shapes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/shape"
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "release_views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/release_view"
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)"
    },
    "identifier": {
      "type": "string",
      "pattern": "[a-z][a-z0-9_]*"
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "duckdb_type",
        "nullable"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "duckdb_type": {
          "type": "string",
          "pattern": "[A-Z][A-Z0-9_]*(\\([0-9]+(,[0-9]+)?\\))?"
        },
        "nullable": {
          "type": "boolean"
        }
      }
    },
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "duckdb_type",
        "required",
        "nullable",
        "origin"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "duckdb_type": {
          "type": "string",
          "pattern": "[A-Z][A-Z0-9_]*(\\([0-9]+(,[0-9]+)?\\))?"
        },
        "required": {
          "type": "boolean"
        },
        "nullable": {
          "type": "boolean"
        },
        "origin": {
          "enum": [
            "query",
            "relation"
          ]
        }
      }
    },
    "result_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "columns"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/column"
          }
        }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "digest",
        "arguments",
        "results",
        "behaviors"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "sha256\\.[0-9a-f]{64}"
        },
        "digest": {
          "type": "string",
          "pattern": "[0-9a-f]{64}"
        },
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/argument"
          }
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/result_variant"
          }
        },
        "behaviors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "[a-z][a-z0-9_]*"
          }
        }
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release",
        "state",
        "classification",
        "shape",
        "rfc",
        "rationale"
      ],
      "properties": {
        "release": {
          "$ref": "#/$defs/semver"
        },
        "state": {
          "enum": [
            "active",
            "deprecated",
            "removed"
          ]
        },
        "classification": {
          "enum": [
            "baseline",
            "compatible_addition",
            "compatible_change",
            "deprecation",
            "incompatible_change",
            "removal"
          ]
        },
        "shape": {
          "type": [
            "string",
            "null"
          ]
        },
        "rfc": {
          "type": "string",
          "pattern": "RFC [0-9]{4}"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner",
        "catalog",
        "schema",
        "kind",
        "name",
        "revisions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "sql\\.table_function\\.system\\.main\\.[a-z][a-z0-9_]*"
        },
        "owner": {
          "const": "query-experience"
        },
        "catalog": {
          "const": "system"
        },
        "schema": {
          "const": "main"
        },
        "kind": {
          "const": "table_function"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "revisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/revision"
          }
        }
      }
    },
    "release_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release",
        "status",
        "active",
        "removed"
      ],
      "properties": {
        "release": {
          "$ref": "#/$defs/semver"
        },
        "status": {
          "enum": [
            "shipped",
            "candidate"
          ]
        },
        "active": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "sql\\.table_function\\.system\\.main\\.[a-z][a-z0-9_]*"
          }
        },
        "removed": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "sql\\.table_function\\.system\\.main\\.[a-z][a-z0-9_]*"
          }
        }
      }
    }
  }
}
